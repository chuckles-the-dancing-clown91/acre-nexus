# Postgres connection string.
DATABASE_URL=postgres://acre:acre@localhost:5432/acre
# HMAC secret for signing JWT access tokens. REQUIRED when APP_ENV=production:
# the server refuses to boot if it's unset, still this dev default, or shorter
# than 32 chars. Generate one with: openssl rand -hex 32
JWT_SECRET=dev-insecure-change-me
# 32-byte AES-256-GCM key (64 hex chars) for PII encryption (SSN / gov IDs).
# Generate with: openssl rand -hex 32
# REQUIRED when APP_ENV=production — the server refuses to boot without a valid
# key. In dev, if unset a key is derived from JWT_SECRET.
PII_ENC_KEY=
# 32-byte AES-256-GCM key (64 hex chars) for integration-credential encryption
# (the secrets vault). Independent from PII_ENC_KEY so the two rotate
# separately. REQUIRED when APP_ENV=production — the server refuses to boot
# without it; in dev a key is derived from JWT_SECRET.
SECRETS_ENC_KEY=
# Deployment environment. Setting "production" (or "prod") turns on fail-closed
# handling: JWT_SECRET, PII_ENC_KEY, and SECRETS_ENC_KEY must all be explicitly
# set (see above), and AUTO_MIGRATE defaults OFF (no unattended migrate/seed).
APP_ENV=development
# Access-token lifetime (seconds).
ACCESS_TTL_SECS=900
# Refresh-token lifetime (seconds).
REFRESH_TTL_SECS=2592000
# Run migrations + seed on boot (1/0). Defaults on in dev, but OFF in
# production (APP_ENV=production) unless explicitly set to 1 — so a prod env
# never migrates or seeds unattended. Demo data is never seeded in production
# regardless. For prod, run migrations as an explicit deploy step instead:
#   cargo run -p migration -- up
AUTO_MIGRATE=1
# Rocket bind address/port.
ROCKET_ADDRESS=0.0.0.0
ROCKET_PORT=8000
# Log level filter (tracing's EnvFilter syntax).
RUST_LOG=info,sqlx=warn
# Log output format: unset/anything else = human-readable text; "json" = one
# JSON object per line (for log aggregators; see docs/AUDIT.md).
LOG_FORMAT=

# ---- Object storage (document service) ----
# "local" (default; blobs under STORAGE_DIR, served via signed /storage/local
# URLs) or "s3" (any S3-compatible store via presigned URLs).
STORAGE_BACKEND=local
STORAGE_DIR=./data/objects
# Public base URL of this API — local signed URLs are minted against it.
PUBLIC_API_URL=http://localhost:8000
# Public base URL of the frontend app — e-signature signing links
# (/sign/<token>?tenant=<slug>) are minted against it.
PUBLIC_APP_URL=http://localhost:3000
# Required when STORAGE_BACKEND=s3:
S3_BUCKET=
S3_REGION=us-east-1
# Custom endpoint for R2/MinIO (path-style); leave empty for AWS.
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Providers ----
# Comma-separated provider keys allowed to make LIVE calls ("all" for every
# provider; notification channels are email, sms, push, chat). Unlisted
# providers use their deterministic simulated implementation — the default,
# and what CI/demos exercise.
#
# Federated login (issue #63) uses the same gate: add "google"/"microsoft"/
# "apple" to enable real OAuth (and store oauth.<provider>.client_id +
# oauth.<provider>.client_secret in the secrets vault). Unlisted → a hermetic
# sandbox provider runs, so "Log in with …" works offline. The OAuth redirect
# URI is <PUBLIC_APP_URL>/auth/callback.
LIVE_PROVIDERS=

# ---- Web Push (VAPID) ----
# Contact for push services, per RFC 8292 (mailto: or https:). The VAPID
# keypair itself is generated automatically and kept in the secrets vault.
VAPID_SUBJECT=mailto:ops@acrenexus.example

# Postgres connection string.
DATABASE_URL=postgres://acre:acre@localhost:5432/acre
# HMAC secret for signing JWT access tokens. CHANGE IN PRODUCTION.
JWT_SECRET=dev-insecure-change-me
# 32-byte AES-256-GCM key (64 hex chars) for PII encryption (SSN / gov IDs).
# Generate with: openssl rand -hex 32
# If unset, a key is derived from JWT_SECRET (DEV ONLY — set this in production).
PII_ENC_KEY=
# 32-byte AES-256-GCM key (64 hex chars) for integration-credential encryption
# (the secrets vault). Independent from PII_ENC_KEY so the two rotate
# separately. REQUIRED when APP_ENV=production — the server refuses to boot
# without it; in dev a key is derived from JWT_SECRET.
SECRETS_ENC_KEY=
# Deployment environment. Setting "production" turns on fail-closed key
# handling (see SECRETS_ENC_KEY).
APP_ENV=development
# Access-token lifetime (seconds).
ACCESS_TTL_SECS=900
# Refresh-token lifetime (seconds).
REFRESH_TTL_SECS=2592000
# Run migrations + seed on boot (1/0).
AUTO_MIGRATE=1
# Rocket bind address/port.
ROCKET_ADDRESS=0.0.0.0
ROCKET_PORT=8000
# Log level filter (tracing's EnvFilter syntax).
RUST_LOG=info,sqlx=warn
# Log output format: unset/anything else = human-readable text; "json" = one
# JSON object per line (for log aggregators; see docs/AUDIT.md).
LOG_FORMAT=

# ---- Object storage (document service) ----
# "local" (default; blobs under STORAGE_DIR, served via signed /storage/local
# URLs) or "s3" (any S3-compatible store via presigned URLs).
STORAGE_BACKEND=local
STORAGE_DIR=./data/objects
# Public base URL of this API — local signed URLs are minted against it.
PUBLIC_API_URL=http://localhost:8000
# Required when STORAGE_BACKEND=s3:
S3_BUCKET=
S3_REGION=us-east-1
# Custom endpoint for R2/MinIO (path-style); leave empty for AWS.
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Providers ----
# Comma-separated provider keys allowed to make LIVE calls ("all" for every
# provider). Unlisted providers use their deterministic simulated
# implementation — the default, and what CI/demos exercise.
LIVE_PROVIDERS=

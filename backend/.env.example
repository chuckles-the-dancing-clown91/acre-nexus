# ── Databases ────────────────────────────────────────────────────────────────
# The platform uses THREE databases — user / property / client. Each has a
# RUNTIME url (connect as the least-privilege `_app` role so Postgres
# row-level-security is enforced) and an OWNER url (used only to run migrations,
# which need DDL privileges).
#
# `scripts/setup-postgres.sh` provisions all three databases + roles and writes
# these exact vars: a per-service file plus a combined `scripts/secrets/acre.env`
# (which it can install straight into this backend/.env for you).
#
# Runtime (app) connections — non-owner `_app` role:
USER_DATABASE_URL=postgres://acre_user_app:CHANGEME@127.0.0.1:5432/acre_user
PROPERTY_DATABASE_URL=postgres://acre_property_app:CHANGEME@127.0.0.1:5432/acre_property
CLIENT_DATABASE_URL=postgres://acre_client_app:CHANGEME@127.0.0.1:5432/acre_client
# Owner (DDL/migration) connections — schema-owner role:
USER_DATABASE_OWNER_URL=postgres://acre_user_owner:CHANGEME@127.0.0.1:5432/acre_user
PROPERTY_DATABASE_OWNER_URL=postgres://acre_property_owner:CHANGEME@127.0.0.1:5432/acre_property
CLIENT_DATABASE_OWNER_URL=postgres://acre_client_owner:CHANGEME@127.0.0.1:5432/acre_client
#
# Simple single-database dev fallback: set only DATABASE_URL and all six vars
# above fall back to it (everything in one database, as the owner role, with RLS
# permissive). Convenient locally; do NOT use in production.
# DATABASE_URL=postgres://acre:acre@localhost:5432/acre

# ── Secrets / runtime ─────────────────────────────────────────────────────────
# HMAC secret for signing JWT access tokens. CHANGE IN PRODUCTION.
JWT_SECRET=dev-insecure-change-me
# 32-byte AES-256-GCM key (64 hex chars) for PII encryption (SSN / gov IDs).
# Generate with: openssl rand -hex 32
# If unset, a key is derived from JWT_SECRET (DEV ONLY — set this in production).
PII_ENC_KEY=
# Access-token lifetime (seconds).
ACCESS_TTL_SECS=900
# Refresh-token lifetime (seconds).
REFRESH_TTL_SECS=2592000
# Run migrations (per database, as the owner role) + seed on boot (1/0).
AUTO_MIGRATE=1
# Rocket bind address/port.
ROCKET_ADDRESS=0.0.0.0
ROCKET_PORT=8000

# ── Document storage (LLC logos + documents + generated PDFs) ─────────────────
# Platform-managed default backend. A tenant can override this with their own
# bucket via PUT /storage/config (BYO credentials are encrypted at rest).
# Provider: local | s3 | gcs.
STORAGE_PROVIDER=local
# `local`: base directory for stored objects.
STORAGE_LOCAL_PATH=./.storage
# `s3` / `gcs`: bucket + optional key prefix.
# STORAGE_BUCKET=acre-documents
# STORAGE_PREFIX=
# `s3` only: region, optional custom endpoint (MinIO/R2), and credentials.
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_ALLOW_HTTP=0
# `gcs` only: the service-account key JSON (whole file contents).
# STORAGE_GCS_SERVICE_ACCOUNT_JSON=

# ── Outbound email (tenant letters / generated documents) ─────────────────────
# Provider: log (simulated; records to sent_email, never sends) | smtp.
EMAIL_PROVIDER=log
EMAIL_FROM=no-reply@acre.example
# smtp only:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_STARTTLS=1
